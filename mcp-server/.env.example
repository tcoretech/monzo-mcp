# Monzo OAuth Client Credentials
# Create a confidential OAuth client at https://developers.monzo.com/
# Set redirect URL to: http://localhost:3118/callback

MONZO_CLIENT_ID=oauth2client_xxxxxxxxxxxxxxxxxxxx
MONZO_CLIENT_SECRET=mnzconf.xxxxxxxxxxxxxxxxxxxxxxxx

# That's it! Access tokens, refresh tokens, and account ID are
# handled automatically by the server via OAuth browser flow.
