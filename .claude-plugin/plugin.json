{
  "name": "monzo",
  "version": "1.0.7",
  "description": "Read-only Monzo banking integration — balances, transactions, pots, and spending analysis via MCP server",
  "author": {
    "name": "tcoretech",
    "url": "https://github.com/tcoretech"
  },
  "license": "MIT",
  "homepage": "https://github.com/tcoretech/monzo-mcp",
  "category": "finance",
  "keywords": ["monzo", "banking", "finance", "mcp", "spending"],
  "userConfig": {
    "client_id": {
      "title": "Monzo Client ID",
      "description": "OAuth Client ID from developers.monzo.com",
      "type": "string",
      "sensitive": true
    },
    "client_secret": {
      "title": "Monzo Client Secret",
      "description": "OAuth Client Secret from developers.monzo.com",
      "type": "string",
      "sensitive": true
    }
  },
  "mcpServers": {
    "monzo": {
      "command": "python",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp-server/server.py"],
      "env": {
        "MONZO_CLIENT_ID": "${user_config.client_id}",
        "MONZO_CLIENT_SECRET": "${user_config.client_secret}"
      },
      "transport": "stdio"
    }
  },
  "skills": "./skills/"
}
