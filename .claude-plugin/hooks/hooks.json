{
  "description": "Monzo plugin hooks — checks OAuth token status on session start",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/check-monzo-auth.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
